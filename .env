DB_PASSWORD=blume_local
DB_NAME=blume
RECORD_DB_PASSWORD=recordings_local
RECORD_DB_NAME=recordings
SERVER_IP=192.168.68.69

JWT_SECRET=local-dev-secret-change-in-production-must-be-256bits
JWT_EXPIRATION_SECONDS=86400

# ── Stream Engine ─────────────────────────────────────────────────────────────
# Clave que comparte el servidor Go y el front. OBS: stream key = este valor.
STREAM_KEY=devkey

# ── MinIO / recordings storage ─────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=recordings

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# ── HLS (no usado en stream-engine local, requerido por Spring) ───────────────
HLS_SIGNING_SECRET=unused
HLS_URL_TTL_SECONDS=3600

# ── Mail (opcional para pruebas locales) ──────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=dummy
MAIL_PASSWORD=dummy

DOCKER_API_VERSION=1.52

# ── Firebase ──────────────────────────────────────────────────────────────────
# El archivo se monta directamente en el contenedor vía docker-compose.yml.
# Asegúrate de que exista: blume_business_logic_ms/firebase/serviceAccountKey.json
# No necesitas configurar ninguna variable de entorno adicional para Firebase.

# ── Stream activities (Phoenix) + Postgres ────────────────────────────────────
# Genera SECRET_KEY_BASE con: docker run --rm hexpm/elixir:1.16.3-erlang-26.2.5-alpine-3.19.1 mix phx.gen.secret
ACTIVITIES_SECRET_KEY_BASE=replace_with_output_of_mix_phx_gen_secret
ACTIVITIES_DB_USER=blume
ACTIVITIES_DB_PASSWORD=postgres
ACTIVITIES_DB_NAME=stream_activities

# Firebase client credentials (baked into the Next.js bundle at build time)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyAyHKM4yWrGeOloLmMWv6vjjxnCN4skWbA
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=blume-dev-fb69e.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=blume-dev-fb69e
